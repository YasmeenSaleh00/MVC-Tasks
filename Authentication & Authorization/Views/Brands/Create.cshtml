@model Practise_Database_Migration.Models.Brand

@{
    ViewData["Title"] = "Create";
}
@section Styles {
    <style>

        body {
            background-color: #FFF5F8;
        }

        .card {
            border-radius: 20px;
            border: 1px solid #FFB6C1;
            box-shadow: 0 10px 20px rgba(214, 51, 108, 0.05) !important;
            overflow: hidden;
        }

        .card-header {
            background-color: #D6336C !important;
            color: white;
            font-weight: bold;
            border-bottom: none;
        }

        .form-control {
            border: 1px solid #FFB6C1 !important;
            border-radius: 10px;
            padding: 10px 15px;
        }

            .form-control:focus {
                border-color: #FF4081;
                box-shadow: 0 0 0 0.2rem rgba(255, 64, 129, 0.1);
                outline: none;
            }

        .btn-primary {
            background: linear-gradient(45deg, #D6336C, #FF4081) !important;
            border: none;
            border-radius: 10px;
            padding: 12px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

            .btn-primary:hover {
                background: linear-gradient(45deg, #FF4081, #D6336C) !important;
                transform: translateY(-3px) !important;
                box-shadow: 0 5px 15px rgba(214, 51, 108, 0.3) !important;
            }

        .back-link {
            color: #D6336C !important;
            text-decoration: none;
            font-weight: 500;
        }

            .back-link:hover {
                color: #FF4081 !important;
            }
    </style>
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white text-center">
                    <h4 class="mb-0">Add New Brand</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-3">
                            <label asp-for="Name" class="form-label fw-bold"></label>
                            <input asp-for="Name" class="form-control" placeholder="Enter brand name..." />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Description" class="form-label fw-bold"></label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Write a short description..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label class="form-label fw-bold">Upload Image</label>
                            <input type="file" name="ImagePath" class="form-control shadow-sm" accept="image/*" />
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">Create Brand</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel & Back</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
