@model Practise_Database_Migration.Models.Brand

@{
    ViewData["Title"] = "Delete Brand";
}
@section Styles {
    <style>
        body {
            background-color: #FFF5F8;
        }

        .delete-card {
            border-radius: 25px;
            border: none;
            overflow: hidden;
            background: white;
            box-shadow: 0 15px 35px rgba(214, 51, 108, 0.1) !important;
        }

        .delete-header {
            background: linear-gradient(45deg, #e63946, #D6336C);
            color: white;
            padding: 30px;
            text-align: center;
        }

        .warning-box {
            background-color: #fff0f3;
            border-left: 5px solid #e63946;
            padding: 15px;
            margin-bottom: 25px;
            border-radius: 10px;
            color: #d00000;
            font-weight: 600;
        }

        .info-label {
            color: #D6336C;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.8rem;
            margin-bottom: 2px;
        }

        .info-value {
            color: #495057;
            font-size: 1rem;
            margin-bottom: 15px;
            padding-bottom: 5px;
            border-bottom: 1px solid #FFF5F8;
        }

        .img-delete-preview {
            border-radius: 15px;
            border: 3px solid #FFF5F8;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            object-fit: cover;
        }

        .btn-danger-custom {
            background: linear-gradient(45deg, #e63946, #ff4d6d);
            color: white !important;
            border: none;
            border-radius: 12px;
            padding: 12px 30px;
            font-weight: 600;
            transition: all 0.3s;
        }

            .btn-danger-custom:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(230, 57, 70, 0.3);
            }

        .btn-cancel {
            border-radius: 12px;
            padding: 12px 30px;
            border: 1px solid #FFB6C1;
            color: #D6336C !important;
            font-weight: 600;
            text-decoration: none;
        }
    </style>
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card delete-card">
                <div class="delete-header">
                    <i class="bi bi-exclamation-triangle-fill fs-1 mb-2"></i>
                    <h2 class="mb-0">Delete Confirmation</h2>
                </div>

                <div class="card-body p-4 p-md-5">
                    <div class="warning-box">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        Are you sure you want to permanently delete this brand? This action cannot be undone.
                    </div>

                    <div class="row align-items-center">
                        <div class="col-md-4 text-center mb-4 mb-md-0">
                            <img src="~/images/Brands/@Model.ImagePath" width="180" height="180" class="img-delete-preview" alt="Category Image" />
                        </div>

                        <div class="col-md-8">
                            <div class="info-label">Brand Name</div>
                            <div class="info-value fw-bold">@Model.Name</div>

                            <div class="info-label">Description</div>
                            <div class="info-value small">@Model.Description</div>

                            <div class="info-label">Created On</div>
                            <div class="info-value small">@Model.CreationDate?.ToString("dd MMM yyyy")</div>
                        </div>
                    </div>

                    <hr class="my-4" style="opacity: 0.1;" />

                    <div class="d-flex justify-content-center gap-3">
                        <form asp-action="Delete">
                            <input type="hidden" asp-for="Id" />
                            <button type="submit" class="btn btn-danger-custom">
                                <i class="bi bi-trash3 me-1"></i> Confirm Delete
                            </button>
                        </form>
                        <a asp-action="Index" class="btn btn-cancel">
                            Cancel & Go Back
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
