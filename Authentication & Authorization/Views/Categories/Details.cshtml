@model Practise_Database_Migration.Models.Category

@{
    ViewData["Title"] = "Category Details";
}

@section Styles {
    <style>
        body {
            background-color: #FFF5F8;
        }

        .details-card {
            border-radius: 25px;
            border: none;
            overflow: hidden;
            background: white;
            box-shadow: 0 15px 35px rgba(214, 51, 108, 0.1) !important;
        }

        .category-header {
            background: linear-gradient(45deg, #D6336C, #FF4081);
            color: white;
            padding: 30px;
            text-align: center;
        }

        .info-label {
            color: #D6336C;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }

        .info-value {
            color: #495057;
            font-size: 1.1rem;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 1px solid #FFF5F8;
        }

        .img-preview-container {
            background: #FFF5F8;
            border-radius: 20px;
            padding: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100%;
        }

            .img-preview-container img {
                max-width: 100%;
                border-radius: 15px;
                box-shadow: 0 8px 20px rgba(0,0,0,0.1);
                transition: transform 0.3s ease;
            }

                .img-preview-container img:hover {
                    transform: scale(1.05);
                }

        .status-badge {
            padding: 8px 20px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.9rem;
        }

        .btn-edit {
            background: linear-gradient(45deg, #D6336C, #FF4081);
            color: white !important;
            border-radius: 12px;
            padding: 12px 30px;
            font-weight: 600;
            border: none;
            transition: all 0.3s;
        }

            .btn-edit:hover {
                transform: translateY(-3px);
                box-shadow: 0 5px 15px rgba(214, 51, 108, 0.3);
            }

        .btn-back {
            border-radius: 12px;
            padding: 12px 30px;
            border: 1px solid #FFB6C1;
            color: #D6336C !important;
            font-weight: 600;
        }
    </style>
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card details-card">
                <div class="category-header">
                    <h2 class="mb-0">Category Overview</h2>
                    <p class="mb-0 opacity-75">Detailed information about @Model.Name</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <div class="row">
                        <div class="col-md-5 mb-4 mb-md-0">
                            <div class="img-preview-container">
                                <img src="~/images/Categories/@Model.ImagePath" alt="@Model.Name" />
                            </div>
                        </div>

                        <div class="col-md-7 ps-md-5">
                            <div class="row">
                                <div class="col-12">
                                    <div class="info-label">Category Name</div>
                                    <div class="info-value fw-bold text-dark">@Model.Name</div>
                                </div>

                                <div class="col-12">
                                    <div class="info-label">Description</div>
                                    <div class="info-value">@Model.Description</div>
                                </div>

                                <div class="col-6">
                                    <div class="info-label">Created At</div>
                                    <div class="info-value small">@Model.CreationDate?.ToString("dd MMM yyyy")</div>
                                </div>

                                <div class="col-6">
                                    <div class="info-label">Last Updated</div>
                                    <div class="info-value small">@(Model.UpdatedDate?.ToString("dd MMM yyyy") ?? "Never")</div>
                                </div>

                                <div class="col-12">
                                    <div class="info-label">Current Status</div>
                                    <div class="info-value border-0">
                                        @if (@Model.IsDeleted == true)
                                        {
                                            <span class="status-badge bg-danger bg-opacity-10 text-danger">
                                                <i class="bi bi-x-circle me-1"></i> Not Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="status-badge bg-success bg-opacity-10 text-success">
                                                <i class="bi bi-check-circle me-1"></i> Active
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="mt-4 d-flex gap-3">
                                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-edit shadow-sm">
                                    <i class="bi bi-pencil-square me-1"></i> Edit Category
                                </a>
                                <a asp-action="Index" class="btn btn-back">
                                    <i class="bi bi-arrow-left me-1"></i> Back to List
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>